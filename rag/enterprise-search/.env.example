# Choose provider: "gemini" (default), "openai", or "openrouter"
LLM_PROVIDER=gemini

# Model name:
# e.g., for gemini: "gemini-1.5-flash-latest"
# e.g., for openai: "gpt-4o"
# e.g., for openrouter: "meta-llama/llama-3-8b-instruct:free", "zhipu/glm-5.2", or "moonshotai/kimi-k2.6"
CHAT_MODEL=gemini-1.5-flash-latest

# API Keys (provide keys for your selected provider)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
